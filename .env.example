# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ADMIN_PASSWORD: Password to login to the administrator console to reply/update post status (Default: carrier1234)
ADMIN_PASSWORD="carrier1234"

# SMTP_HOST: The SMTP Host address to deliver notification e-mails instantly
SMTP_HOST="smtp.gmail.com"
# SMTP_PORT: Port number to communicate with the SMTP Server (E.g., 587 or 465)
SMTP_PORT="587"
# SMTP_USER: Mail sender authentication username (E.g., alerts@yourdomain.com)
SMTP_USER=""
# SMTP_PASS: Mail sender authentication credentials password or App Password
SMTP_PASS=""
# SMTP_SECURE: Set to true if communicating on port 465 with SSL, otherwise false
SMTP_SECURE="false"
# SMTP_FROM: Customized Sender Display Name and address. Fallback is SMTP_USER
SMTP_FROM="\"Carrier AC Alarm\" <alerts@yourdomain.com>"

# NOTIFICATION_RECEIVER: Target email address of the administrator who should receive inquiries (Defaults to kagemasta@gmail.com)
NOTIFICATION_RECEIVER="kagemasta@gmail.com"

# VITE_KAKAO_APP_KEY: Optional Kakao Maps JavaScript App Key for loading dynamic maps
VITE_KAKAO_APP_KEY=""


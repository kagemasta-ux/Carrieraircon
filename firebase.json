{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "server.cjs",
      "server.cjs.map"
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "run": {
          "serviceId": "carrieraircon-web",
          "region": "asia-east1"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
